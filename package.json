{
  "name": "ai-digital-health-system",
  "version": "1.0.0",
  "description": "AI-Powered Digital Health System for 200-bed hospital",
  "main": "backend/src/server.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:backend\"",
    "dev:web": "cd web && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:web && npm run build:backend",
    "build:web": "cd web && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "jest",
    "migrate": "cd backend && npm run migrate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "healthcare",
    "hospital",
    "ehr",
    "ai",
    "offline-first",
    "react",
    "react-native"
  ],
  "author": "Hospital Digital Health Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "shared",
    "web",
    "mobile",
    "backend"
  ]
}
